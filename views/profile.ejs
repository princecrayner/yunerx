<!DOCTYPE html>
<html>

<head>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Profile</title>

<link rel="stylesheet" href="/css/profile.css">

<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

</head>

<body>
  
    <!-- UPLOAD -->
    <div class="footer-icon upload-btn">
        <i class='bx bx-upload'></i>
    </div>


    <!-- MENU -->
    <div class="menu-icon" id="menuBtn">☰</div>
    
</div>


<!-- Sidebar -->
<div class="sidebar" id="sidebar">

    <a href="/settings">Settings</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/logout">Logout</a>

    <div class="copyrighttext">

        <p>© 2026 Yunerx</p>

    </div>

</div>

<!-- Overlay -->
<div class="overlay" id="overlay"></div>



<div class="profile-header">

    <!-- PROFILE IMAGE -->
    <div class="profile-image-container">

        <img
            src="<%= user.profileImage ? user.profileImage : '/images/profile.png' %>"
            class="profile-image"
            id="profileImage"
            onerror="
                this.style.display='none';
                document.getElementById('userIcon').style.display='flex';">


        <!-- DEFAULT ICON -->
        <div
            class="default-user-icon"
            id="userIcon"
            style="<%= user.profilePic ? 'display:none;' : 'display:flex;' %>"
        >

            <i class='bx bx-user'></i>

        </div>

    </div>


    <!-- USER INFO -->
    <div class="profile-info">

        <h1><%= user.username %></h1>

        <p><%= user.email %></p>

        <p><%= user.phone %></p>

    </div>

</div>


<!-- UPLOAD PROFILE PICTURE -->
<form
    action="/upload-profile-picture"
    method="POST"
    enctype="multipart/form-data"
    class="upload-profile-form"
>

    <input
        type="file"
        name="profilePic"
        accept="image/*"
        required
    >

    <button type="submit">

        Upload Profile Picture

    </button>

</form>


<h2 style="padding-left:20px;">Your Videos</h2>


<div class="video-grid">

<% videos.forEach(video => { %>

<div class="video-card">

<video controls>

<source src="<%= video.videoUrl %>">

</video>

<p><%= video.title %></p>

</div>

<% }) %>

</div>

<!-- FOOTER -->

<div class="footer">

    <div class="footer-icon chats">
        <i class='bx bx-message-rounded-dots'></i>
    </div>

    <div class="footer-icon upload-btn">
        <i class='bx bx-arrow-up-stroke-square'></i>
    </div>

    <div class="footer-icon videos">
        <i class='bx bx-play-circle'></i>
    </div>

</div>

<script src="/js/footer.js"></script>

</body>
</html>
