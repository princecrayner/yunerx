<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yunerx</title>

    <link rel="stylesheet" href="/style.css">


    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    
 </head>

<body>

<!-- Splash Screen -->
<div class="splash-screen" id="splash">

    <img src="/logo.png" alt="Logo">

    <h1>YUNERX</h1>
    <p>Connect • Learn • Share</p>
    

</div>


<!-- TOPBAR -->
<div class="topbar">

<div class="profile-area">

    <% if (user && user.profilePic) { %>

        <a href="/profile">

            <img
                src="<%= user.profilePic %>"
                class="profile-pic-top"
                alt="Profile"
            >

        </a>

    <% } else { %>

        <a href="/profile">

            <div class="default-user-icon">

                <i class='bx bx-user'></i>

            </div>

        </a>

    <% } %>

    <div class="welcome-text">

        <span>Welcome home,</span>

        <h3>

            <%= user ? user.username : "Guest" %>

        </h3>

    </div>

</div>


    <!-- LOGO -->
    <div class="logo">
        <img src="/logo.png" alt="Logo">
    </div>


</div>


<!-- SLIDER -->
<div class="imgContainer">

    <div class="wrapper">

        <img src="image1.png" alt="image">
        <img src="image2.png" alt="image">
        <img src="image3.png" alt="image">
        <img src="image4.png" alt="image">
        <img src="image5.png" alt="image">



        <img src="image1.png" aria-hidden="true">
        <img src="image2.png" aria-hidden="true">
        <img src="image3.png" aria-hidden="true">
        <img src="image4.png" aria-hidden="true">
        <img src="image5.png" aria-hidden="true">

    </div>

</div>

  

<!-- MAIN CONTENT -->
<div class="objective-section">

    <h1>📚 Yunerx Learning</h1>

<div class="objective-btn">
  
    <a href="/objectivequizes">
        Start Objective Quize
    </a>

    <a href="/theorysubjects">
        View Objective Questions
    </a>
    
</div>    
    
<div class="objective-hdr">
    <h6>Take objective quizzes here</h6>
    
    <h6>Objective questions from all arears</h6>
</div>
</div>


<!-- LEVELS -->

<div class="level-section">

        <h3>Select Level</h3>

        <h6>
            Select your level for theory past questions
        </h6>

<div class="level-btn">
  
    <a href="/levels/level100" class="levelBtn">
        LEVEL 100
    </a>

    <a href="/levels/level200" class="levelBtn">
        LEVEL 200
    </a>

    <a href="/levels/level300" class="levelBtn">
        LEVEL 300
    </a>
</div>
</div>




<!-- Footer -->
<div class="footer">
  
    <!-- HOME -->
    <a href="/" class="footer-icon home">
        <i class='bx bx-home-alt'></i>
    </a>

    <!-- MESSENGER -->
    <div class="footer-icon chats">
        <i class='bx bx-message-rounded-dots'></i>
    </div>

    

    <!-- VIDEOS -->
    <div class="footer-icon videos">
        <i class='bx bx-play-circle'></i>
    </div>
    
    <!-- DOCS -->
    <a href="/docs" class="footer-icon docs">
         <i class='bx bx-file'></i>
    </a>

</div>


<script src="/script.js"></script>
<script src="/js/footer.js"></script>

</body>
</html>
