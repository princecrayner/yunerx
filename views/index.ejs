<!DOCTYPE html>
<html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yunerx</title>

    <link rel="stylesheet" href="/mobile.css" media="(max-width: 767px)">
    <link rel="stylesheet" href="/desktop.css" media="(min-width: 1024px)"> 


    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
</head>

<body>

<!-- Splash Screen -->
<div class="splash-screen" id="splash">

    <img src="/logo.png" alt="Logo">

    <h1>YUNERX</h1>
    <p>Connect • Learn • Share</p>
    

</div>


<!-- TOPBAR -->
<div class="topbar">

    <!-- LOGO -->
    <div class="logo">
        <img src="/logo.png" alt="Logo">
    </div>


<!-- PROFILE -->
<button class="profile-btn">

    <!-- PROFILE IMAGE -->
    <img
        src="<%= user && user.profilePic ? user.profilePic : '/profile.png' %>"
        id="profileImage"
        onerror="
        this.style.display='none';
        document.getElementById('userIcon').style.display='block';">


    <!-- DEFAULT USER ICON -->
    <i
        class='bx bx-user'
        id="userIcon"
        style="<%= user && user.profilePic ? 'display:none;' : 'display:block;' %>"
    ></i>

</button>

    <!-- MENU -->
    <div class="menu-icon" id="menuBtn">☰</div>

</div>


<!-- Sidebar -->
<div class="sidebar" id="sidebar">

    <a href="/settings">Settings</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/logout">Logout</a>

    <div class="copyrighttext">

        <p>© 2026 Yunerx</p>

    </div>

</div>

<!-- Overlay -->
<div class="overlay" id="overlay"></div>


<!-- MAIN CONTENT -->
<div class="container">

    <h1>📚 Yunerx Learning</h1>

    <h6 class="subhead">Take objective quizzes here</h6>

    <a href="/objectivequizes" class="btn bart">
        Start Objective Quize
    </a>

    <h6 class="subhead">
        Objective questions from all areas
    </h6>

    <a href="/theorysubjects" class="btn bart">
        View Objective Questions
    </a>

</div>


<!-- LEVELS -->

<div class="levels-section">

    <h3 class="bart2">Select Level</h3>

    <h6 class="bart2">
        Select your level for theory past questions
    </h6>

    <a href="/levels/level100" class="btn">
        LEVEL 100
    </a>

    <a href="/levels/level200" class="btn">
        LEVEL 200
    </a>

    <a href="/levels/level300" class="btn">
        LEVEL 300
    </a>

</div>


<!-- SLIDER -->
<div class="imgContainer">

    <div class="wrapper">

        <img src="image1.png" alt="image">
        <img src="image2.png" alt="image">
        <img src="image3.png" alt="image">
        <img src="image4.png" alt="image">
        <img src="image5.png" alt="image">



        <img src="image1.png" aria-hidden="true">
        <img src="image2.png" aria-hidden="true">
        <img src="image3.png" aria-hidden="true">
        <img src="image4.png" aria-hidden="true">
        <img src="image5.png" aria-hidden="true">

    </div>

</div>



<!-- Footer -->
<div class="footer">

    <!-- CHATS -->
    <div class="footer-icon chats">
        <i class='bx bx-message-rounded-dots'></i>
    </div>

    <!-- UPLOAD -->
    <div class="footer-icon upload-btn">
        <i class='bx bx-upload'></i>
    </div>

    <!-- VIDEOS -->
    <div class="footer-icon videos">
        <i class='bx bx-play-circle'></i>
    </div>

</div>


<script src="/script.js"></script>
<script src="/js/footer.js"></script>

</body>
</html>
