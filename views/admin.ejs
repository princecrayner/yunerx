<!DOCTYPE html>
<html>
<head>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Upload</title>

    <link rel="stylesheet" href="/style.css">

</head>

<body>

<div class="container">

    <h1>🛠 Admin Dashboard</h1>

</div>

<!-- ================= CSV ================= -->

<div class="container">

    <h2>📤 Upload Questions (CSV)</h2>

    <form
        action="/admin/upload"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="file"
            name="file"
            accept=".csv"
            required
        >

        <br><br>

        <button class="btn">
            Upload CSV
        </button>

    </form>

    <p>
        CSV Format:
        question, A, B, C, D, answer, category
    </p>

</div>

<hr>

<!-- ================= PDF ================= -->

<div class="container">

    <h2>📄 Upload Study Material (PDF)</h2>

    <form
        action="/admin/upload-pdf"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="text"
            name="title"
            placeholder="PDF Title"
            required
        >

        <input
            type="text"
            name="subject"
            placeholder="Subject"
            required
        >

        <input
            type="text"
            name="level"
            placeholder="Level"
            required
        >

        <input
            type="text"
            name="semester"
            placeholder="Semester"
            required
        >

        <input
            type="text"
            name="category"
            placeholder="Category"
            required
        >

        <input
            type="file"
            name="pdf"
            accept=".pdf"
            required
        >

        <br><br>

        <button class="btn">
            Upload PDF
        </button>

    </form>

</div>


<div class="container">
    <h2>📄 Upload PDF</h2>

    <input
        type="text"
        id="pdfName"
        placeholder="PDF Name"
    >

    <!-- Hidden file input -->
    <input
        type="file"
        id="pdfInput"
        accept=".pdf"
        hidden
    >

    <br><br>

    <!-- Opens the file explorer -->
    <button
        type="button"
        id="uploadBtn"
        class="btn"
    >
        Choose PDF
    </button>

    <p id="selectedFile">No PDF selected.</p>
</div>

<script src="/js/script.js"></script>

</body>
</html>