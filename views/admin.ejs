<!DOCTYPE html>
<html>
<head>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Upload</title>

    <link rel="stylesheet" href="/style.css">
    
    <style>
.pdf-card{

    background:#fff;

    border-radius:10px;

    padding:15px;

    margin:15px 0;

    box-shadow:0 2px 8px rgba(0,0,0,.1);

}

.pdf-card h3{

    margin-bottom:10px;

}

.pdf-card p{

    margin:4px 0;

}
    </style>

</head>

<body>

<div class="container">

    <h1>🛠 Admin Dashboard</h1>

</div>

<!-- ================= CSV ================= -->

<div class="container">

    <h2>📤 Upload Questions (CSV)</h2>

    <form
        action="/admin/upload"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="file"
            name="file"
            accept=".csv"
            required
        >

        <br><br>

        <button class="btn">
            Upload CSV
        </button>

    </form>

    <p>
        CSV Format:
        question, A, B, C, D, answer, category
    </p>

</div>

<hr>


<!-- ================= OBJECTIVE PAST QUESTIONS ================= -->

<div class="container">

    <h2>📝 Upload Objective Past Questions (PDF)</h2>

    <p>
        Upload objective past question papers in PDF format.
    </p>

    <form
        action="/admin/upload-objective-pdf"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="text"
            name="title"
            placeholder="Past Question Title"
            required
        >

        <input
            type="text"
            name="subject"
            placeholder="Subject"
            required
        >

        <input
            type="text"
            name="level"
            placeholder="Level"
            required
        >

        <input
            type="text"
            name="semester"
            placeholder="Semester"
            required
        >

        <input
            type="file"
            name="pdf"
            accept=".pdf"
            required
        >

        <br><br>

        <button class="btn">
            Upload Objective PDF
        </button>

    </form>

</div>

<hr>


<!-- ================= PDF ================= -->

<div class="container">

    <h2>📄 Upload Study Material (PDF)</h2>

    <form
        action="/admin/upload-pdf"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="text"
            name="title"
            placeholder="PDF Title"
            required
        >

        <input
            type="text"
            name="subject"
            placeholder="Subject"
            required
        >

        <input
            type="text"
            name="level"
            placeholder="Level"
            required
        >

        <input
            type="text"
            name="semester"
            placeholder="Semester"
            required
        >

        <input
            type="text"
            name="category"
            placeholder="Category"
            required
        >

        <input
            type="file"
            name="pdf"
            accept=".pdf"
            required
        >

        <br><br>

        <button class="btn">
            Upload PDF
        </button>

    </form>

</div>

<hr>


<div class="container">

    <h2>📚 Upload Docs Library</h2>

    <p>

        Upload general learning materials for students.

    </p>

    <form
        action="/docs/upload"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="text"
            name="name"
            placeholder="Document Title"
            required
        >

        <br><br>

        <input
            type="file"
            name="pdf"
            accept=".pdf"
            required
        >

        <br><br>

        <button class="btn">

            Upload Document

        </button>

    </form>

</div>




<hr>

<div class="container">

    <h2>📂 Docs Library</h2>

    <% if(docs.length === 0){ %>

        <p>No documents uploaded yet.</p>

    <% } %>

    <% docs.forEach(doc => { %>

        <div class="pdf-card">

            <h3>

                <%= doc.name %>

            </h3>

            <p>

                Uploaded:
                <%= new Date(doc.uploadedAt).toLocaleDateString() %>

            </p>

            <a
                href="<%= doc.pdfUrl %>"
                target="_blank"
                class="btn"
            >
                👁 Preview
            </a>

            <a
                href="/docs/edit/<%= doc._id %>"
                class="btn"
            >
                ✏ Edit
            </a>

            <a
                href="/docs/delete/<%= doc._id %>"
                class="btn"
            >
                🗑 Delete
            </a>

        </div>

        <hr>

    <% }) %>

</div>

<script src="/js/script.js"></script>

</body>
</html>