<!DOCTYPE html>
<html>
<head>

<title>Users</title>

<link rel="stylesheet" href="/css/chats.css">

</head>
<body>

<div class="chat-container">

<h1>Users</h1>

<% users.forEach(user => { %>

<div class="message">

<h3><%= user.username %></h3>

<p><%= user.phone %></p>

<button>Chat</button>

</div>

<% }) %>

</div>

</body>
</html>
