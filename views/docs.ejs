<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Documents</title>

    <link rel="stylesheet" href="/style.css">
    
    <style>
.doc-card{

    background:#fff;

    padding:18px;

    margin:15px 0;

    border-radius:12px;

    box-shadow:0 2px 10px rgba(0,0,0,.1);

}

.doc-card h3{

    margin-bottom:15px;

}

.doc-card .btn{

    display:inline-block;

    text-decoration:none;

}
    </style>
</head>
<body>

<div class="container">

    <h2>Documents</h2>

<div id="docsContainer">

    <% if(docs.length === 0){ %>

        <p>No study materials uploaded yet.</p>

    <% } %>

    <% docs.forEach(doc => { %>

        <div class="doc-card">

            <h3><%= doc.name %></h3>

            <a
                href="<%= doc.pdfUrl %>"
                target="_blank"
                class="btn"
            >
                📖 Open PDF
            </a>

        </div>

    <% }) %>

</div>

</div>

<script src="/js/script.js"></script>

</body>
</html>