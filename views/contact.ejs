<!DOCTYPE html>
<html>

<head>

    <title>Contact SitApp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/style.css">

    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

    <style>

        .contact-container{

            width: 85%;
            max-width: 800px;

            background: white;

            margin: auto;
            margin-top: 90px;
            margin-bottom: 100px;

            padding: 30px;

            border-radius: 20px;

            box-shadow: 0 0 20px rgba(0,0,0,0.1);

            text-align: center;

        }

        .contact-title{

            font-size: 35px;
            color: #2563eb;

            margin-bottom: 10px;

        }

        .contact-sub{

            color: gray;

            margin-bottom: 40px;

        }

        .contact-card{

            background: #f3f4f6;

            padding: 20px;

            border-radius: 15px;

            margin-bottom: 20px;

            transition: 0.3s ease;

        }

        .contact-card:hover{

            transform: translateY(-5px);

            box-shadow: 0 0 15px rgba(0,0,0,0.1);

        }

        .contact-card i{

            font-size: 45px;

            color: #2563eb;

            margin-bottom: 10px;

        }

        .contact-card h2{

            margin-bottom: 10px;

        }

        .contact-card a{

            color: #2563eb;

            text-decoration: none;

            font-weight: bold;

        }

        .support-box{

            margin-top: 40px;

            background: #111827;

            color: white;

            padding: 25px;

            border-radius: 15px;

        }

        .support-box h2{

            margin-bottom: 10px;

        }

    </style>

</head>

<body>

<div class="contact-container">

    <h1 class="contact-title">
        Contact SitApp
    </h1>

    <p class="contact-sub">
        Need help, support, partnership, or want to report an issue? Contact us through any platform below.
    </p>

    <!-- EMAIL -->

    <div class="contact-card">

        <i class='bx bx-envelope'></i>

        <h2>Email Support</h2>

        <p>
            For business inquiries, support, or educational partnerships.
        </p>

        <a href="mailto:your@email.com">
            your@email.com
        </a>

    </div>

    <!-- WHATSAPP -->

    <div class="contact-card">

        <i class='bx bxl-whatsapp'></i>

        <h2>WhatsApp Support</h2>

        <p>
            Fast support and direct communication.
        </p>

        <a href="https://wa.me/233000000000">
            Chat on WhatsApp
        </a>

    </div>

    <!-- INSTAGRAM -->

    <div class="contact-card">

        <i class='bx bxl-instagram'></i>

        <h2>Instagram</h2>

        <p>
            Follow updates and community activities.
        </p>

        <a href="#">
            @sitapp
        </a>

    </div>

    <!-- FACEBOOK -->

    <div class="contact-card">

        <i class='bx bxl-facebook-circle'></i>

        <h2>Facebook</h2>

        <p>
            Join our learning community.
        </p>

        <a href="#">
            SitApp Official
        </a>

    </div>

    <!-- SUPPORT -->

    <div class="support-box">

        <h2>Support & Safety</h2>

        <p>

            SitApp actively protects users against inappropriate content, abuse, scams, and harmful activities.

            Users can report videos, messages, or accounts that violate community guidelines.

        </p>

    </div>

</div>

</body>

</html>
